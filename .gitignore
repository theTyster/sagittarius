# Claude Code: the project CLAUDE.md IS committed (it carries repo-specific
# operating notes not duplicated in README.md / docs/). The project .claude/
# dir IS committed too — agents/skills developed here (e.g. .claude/agents/)
# travel with the repo. Machine-local overrides — CLAUDE.local.md and
# .claude/settings.local.json — are covered by *.local.* below.
.env
*.local.*

# This repo TRACKS thoughts/ as a working area (notes, the discovery deck, the
# recon-upgrade experiment, in-progress recon dogfood artifacts). The operator's
# global ~/.gitignore_global ignores `thoughts/*` by convention; these two lines
# override that for this repo. Build artifacts inside thoughts/ stay ignored —
# the .lake/ / *.olean rules below are matched last, so they still win.
!thoughts/
!thoughts/**

# Lean build artifacts (regenerable; multi-GB — never commit)
.lake/
lake-packages/
*.olean

# Node.js
node_modules/
package-lock.json

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Logs / temp
*.log
tmp/
temp/
